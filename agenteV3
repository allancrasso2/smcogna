    # -------------------------------------------------------------------------
    # Helpers
    # -------------------------------------------------------------------------
    def log(self, text: str) -> None:
        self.log_txt.insert("end", text + "\n")
        self.log_txt.see("end")

    def clear_log(self) -> None:
        self.log_txt.delete("1.0", "end")

    def set_text(self, widget: scrolledtext.ScrolledText, value: str) -> None:
        widget.delete("1.0", "end")
        widget.insert("1.0", value)

    def run_in_thread(self, fn) -> None:
        t = threading.Thread(target=fn, daemon=True)
        t.start()

    def set_controls_enabled(self, enabled: bool) -> None:
        state = "normal" if enabled else "disabled"
        for control in self._controls:
            try:
                control.configure(state=state)
            except Exception:
                pass

    def start_busy(self, message: str) -> None:
        self._busy = True
        self._busy_start = time.time()
        self.status_var.set(message)
        self.detail_var.set(message)
        self.timer_var.set("Tempo: 00:00")
        self.progress.start(10)
        self._update_timer()
        self.set_controls_enabled(False)

    def busy_step(self, message: str) -> None:
        self.status_var.set(message)
        self.detail_var.set(message)

    def stop_busy(self, message: str) -> None:
        self._busy = False
        self.progress.stop()
        self.status_var.set(message)
        self.detail_var.set(message)
        self.set_controls_enabled(True)
        if self._timer_job:
            try:
                self.root.after_cancel(self._timer_job)
            except Exception:
                pass
            self._timer_job = None

    def _update_timer(self) -> None:
        if not self._busy:
            return
        elapsed = int(time.time() - self._busy_start)
        mm = elapsed // 60
        ss = elapsed % 60
        self.timer_var.set(f"Tempo: {mm:02d}:{ss:02d}")
        self._timer_job = self.root.after(500, self._update_timer)

    def truncate_text(self, text: str, max_chars: int = 14000) -> str:
        if len(text) <= max_chars:
            return text
        return text[:max_chars] + "\n\n[... texto truncado ...]"

    # -------------------------------------------------------------------------
    # Banco de dados / Biblioteca JSON
    # -------------------------------------------------------------------------
    def get_db_connection(self):
        return psycopg2.connect(
            host=self.db_host,
            port=self.db_port,
            dbname=self.db_name,
            user=self.db_user,
            password=self.db_password,
        )

    def ensure_database_objects(self) -> None:
        try:
            with self.get_db_connection() as conn:
                with conn.cursor() as cur:
                    cur.execute(f"CREATE SCHEMA IF NOT EXISTS {self.db_schema};")
                    cur.execute(
                        f"""
                        CREATE TABLE IF NOT EXISTS {self.db_schema}.{self.db_table} (
                            id SERIAL PRIMARY KEY,
                            nome_arquivo VARCHAR(255) NOT NULL,
                            titulo_documento VARCHAR(255),
                            json_conteudo JSONB NOT NULL,
                            total_secoes INTEGER DEFAULT 0,
                            total_tabelas INTEGER DEFAULT 0,
                            total_quadros INTEGER DEFAULT 0,
                            usuario_nome VARCHAR(150),
                            criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                            atualizado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                        );
                        """
                    )
                conn.commit()
            self.log("Schema e tabela verificados com sucesso.")
        except Exception as e:
            self.log(f"Erro ao criar schema/tabela: {e}")
            self.log(traceback.format_exc())
            messagebox.showerror("Erro", f"Falha ao preparar banco de dados\n{e}")

    def reload_json_library(self) -> None:
        try:
            self.loaded_json_files.clear()
            self.json_check_vars.clear()

            for child in self.json_list_container.winfo_children():
                child.destroy()

            with self.get_db_connection() as conn:
                with conn.cursor() as cur:
                    cur.execute(
                        f"""
                        SELECT
                            id,
                            nome_arquivo,
                            titulo_documento,
                            total_secoes,
                            total_tabelas,
                            total_quadros,
                            criado_em,
                            json_conteudo
                        FROM {self.db_schema}.{self.db_table}
                        ORDER BY criado_em DESC;
                        """
                    )
                    rows = cur.fetchall()

            for row in rows:
                record = {
                    "id": row[0],
                    "name": row[1],
                    "title": row[2],
                    "total_secoes": row[3],
                    "total_tabelas": row[4],
                    "total_quadros": row[5],
                    "criado_em": row[6],
                    "data": row[7],
                }
                self.loaded_json_files.append(record)

            for record in self.loaded_json_files:
                key = str(record["id"])
                var = tk.BooleanVar(value=False)
                self.json_check_vars[key] = var

                text = (
                    f"{record['id']} - {record['name']} "
                    f"(seções={record['total_secoes']}, "
                    f"tabelas={record['total_tabelas']}, "
                    f"quadros={record['total_quadros']})"
                )

                chk = ttk.Checkbutton(
                    self.json_list_container,
                    text=text,
                    variable=var,
                    command=self.update_selected_json_info,
                )
                chk.pack(anchor="w", fill="x", padx=4, pady=2)

            self.update_selected_json_info()
            self.log(f"Biblioteca JSON carregada do banco. Registros: {len(self.loaded_json_files)}")

        except Exception as e:
            self.log(f"Erro ao carregar registros do banco: {e}")
            self.log(traceback.format_exc())
            messagebox.showerror("Erro", f"Falha ao carregar JSONs do banco\n{e}")

    def update_selected_json_info(self) -> None:
        count = sum(1 for var in self.json_check_vars.values() if var.get())
        self.json_selected_info_var.set(f"Selecionados: {count}")

    def select_all_jsons(self) -> None:
        for var in self.json_check_vars.values():
            var.set(True)
        self.update_selected_json_info()

    def unselect_all_jsons(self) -> None:
        for var in self.json_check_vars.values():
            var.set(False)
        self.update_selected_json_info()

    def add_current_json_to_library(self) -> None:
        if not self.current_json:
            messagebox.showwarning("Aviso", "Nenhum JSON atual foi gerado.")
            return

        try:
            documento = self.current_json.get("documento", {})
            resumo = self.current_json.get("resumo_estrutura", {})

            nome_arquivo = documento.get("arquivo", "documento_sem_nome.json")
            titulo_documento = documento.get("titulo", "") or nome_arquivo

            with self.get_db_connection() as conn:
                with conn.cursor() as cur:
                    cur.execute(
                        f"""
                        INSERT INTO {self.db_schema}.{self.db_table} (
                            nome_arquivo,
                            titulo_documento,
                            json_conteudo,
                            total_secoes,
                            total_tabelas,
                            total_quadros,
                            usuario_nome
                        )
                        VALUES (%s, %s, %s, %s, %s, %s, %s)
                        RETURNING id;
                        """,
                        (
                            nome_arquivo,
                            titulo_documento,
                            Json(self.current_json),
                            resumo.get("total_secoes", 0),
                            resumo.get("total_tabelas", 0),
                            resumo.get("total_quadros_detectados", 0),
                            self.username_var.get().strip() or "postgres",
                        )
                    )
                    new_id = cur.fetchone()[0]
                conn.commit()

            self.log(f"JSON atual salvo no banco com ID {new_id}.")
            self.reload_json_library()
            messagebox.showinfo("Sucesso", f"JSON salvo no banco com ID {new_id}.")

        except Exception as e:
            self.log(f"Erro ao salvar JSON no banco: {e}")
            self.log(traceback.format_exc())
            messagebox.showerror("Erro", f"Falha ao salvar JSON no banco\n{e}")

    def get_selected_json_records(self) -> List[Dict[str, Any]]:
        selected: List[Dict[str, Any]] = []
        for record in self.loaded_json_files:
            key = str(record["id"])
            var = self.json_check_vars.get(key)
            if var and var.get():
                selected.append(record)
        return selected

    def build_combined_json_context(self) -> tuple[str, List[Dict[str, Any]]]:
        selected = self.get_selected_json_records()

        if not selected:
            if self.current_json:
                payload = {
                    "modo": "json_atual",
                    "documentos": [
                        {
                            "arquivo": self.current_json.get("documento", {}).get("arquivo", "json_atual"),
                            "conteudo": self.current_json
                        }
                    ]
                }
                return json.dumps(payload, indent=2, ensure_ascii=False), []
            return "", []

        payload = {
            "modo": "comparativo" if len(selected) > 1 else "individual",
            "total_documentos": len(selected),
            "documentos": [],
        }

        for record in selected:
            payload["documentos"].append(
                {
                    "id": record["id"],
                    "arquivo": record["name"],
                    "titulo": record["title"],
                    "conteudo": record["data"],
                }
            )

        return json.dumps(payload, indent=2, ensure_ascii=False), selected

    # -------------------------------------------------------------------------
    # Documento
    # -------------------------------------------------------------------------
    def select_docx(self) -> None:
        file_path = filedialog.askopenfilename(
            title="Selecione um DOCX",
            filetypes=[("Arquivos Word", "*.docx"), ("Todos os arquivos", "*.*")]
        )
        if not file_path:
            return
        self.selected_file = file_path
        self.file_label_var.set(file_path)
        self.log(f"Arquivo selecionado: {file_path}")

    def extract_document(self) -> None:
        def worker():
            try:
                if not self.selected_file:
                    messagebox.showwarning("Aviso", "Selecione um DOCX primeiro.")
                    return

                self.start_busy("Extraindo documento...")
                self.busy_step("Lendo DOCX...")
                structure = self.extractor.extract(self.selected_file)

                self.busy_step("Convertendo estrutura para JSON...")
                self.current_json = structure

                preview_text = self._build_preview_text(structure)
                tables_text = self._build_tables_preview(structure)
                json_text = json.dumps(structure, indent=2, ensure_ascii=False)

                def done():
                    self.set_text(self.preview_txt, preview_text)
                    self.set_text(self.tables_preview_txt, tables_text)
                    self.set_text(self.json_txt, json_text)

                    resumo = structure["resumo_estrutura"]
                    self.extract_status_var.set("Extração: concluída")
                    self.json_status_var.set("JSON: gerado")
                    self.table_status_var.set(f"Tabelas: {resumo['total_tabelas']}")
                    self.section_status_var.set(f"Seções: {resumo['total_secoes']}")

                    self.stop_busy("Extração concluída")

                self.root.after(0, done)
                self.log("Documento extraído com sucesso.")
                self.log(json.dumps(structure["resumo_estrutura"], indent=2, ensure_ascii=False))

            except Exception as e:
                self.log(f"Erro ao extrair documento: {e}")
                self.log(traceback.format_exc())
                self.root.after(0, lambda: self.stop_busy("Erro na extração"))
                self.root.after(0, lambda: messagebox.showerror("Erro", str(e)))

        self.run_in_thread(worker)

    def _build_preview_text(self, structure: Dict[str, Any]) -> str:
        lines: List[str] = []
        lines.append("METADADOS")
        lines.append(json.dumps(structure["documento"], indent=2, ensure_ascii=False))
        lines.append("")
        lines.append("SEÇÕES")
        for sec in structure["secoes"][:20]:
            lines.append(f"- {sec['title']} ({sec['level']})")
            if sec["paragraphs"]:
                lines.append(f"  {sec['paragraphs'][0][:300]}")
        return "\n".join(lines)

    def _build_tables_preview(self, structure: Dict[str, Any]) -> str:
        lines: List[str] = []
        for idx, quadro in enumerate(structure["quadros"], start=1):
            lines.append(f"[Quadro {idx}] {quadro['titulo']}")
            if quadro["headers"]:
                lines.append("Headers: " + " | ".join(quadro["headers"]))
            for item in quadro["itens"][:10]:
                lines.append(json.dumps(item, ensure_ascii=False))
            lines.append("")
        if not lines:
            lines.append("Nenhum quadro/tabela detectado.")
        return "\n".join(lines)

    def save_json(self) -> None:
        if not self.current_json:
            messagebox.showwarning("Aviso", "Extraia um documento primeiro.")
            return

        out_path = filedialog.asksaveasfilename(
            title="Salvar JSON",
            defaultextension=".json",
            filetypes=[("JSON", "*.json")]
        )
        if not out_path:
            return

        Path(out_path).write_text(
            json.dumps(self.current_json, indent=2, ensure_ascii=False),
            encoding="utf-8"
        )
        self.log(f"JSON salvo em: {out_path}")
        messagebox.showinfo("Sucesso", f"JSON salvo em:\n{out_path}")

    def generate_prompt_for_ai(self) -> None:
        combined_json_text, selected = self.build_combined_json_context()

        if not combined_json_text:
            messagebox.showwarning("Aviso", "Nenhum JSON disponível. Extraia um documento ou selecione JSONs do banco.")
            return

        query = self.json_query_var.get().strip() if hasattr(self, "json_query_var") else ""
        if not query:
            query = "Liste os principais elementos do documento."

        if len(selected) > 1:
            instruction = (
                "Considere os JSONs estruturados abaixo, extraídos automaticamente de vários documentos DOCX.\n\n"
                f"Pergunta do usuário:\n{query}\n\n"
                "JSONs selecionados:\n"
                f"{self.truncate_text(combined_json_text, 25000)}\n\n"
                "Instruções:\n"
                "- Responda comparando e relacionando os documentos quando fizer sentido.\n"
                "- Diga explicitamente quais arquivos foram considerados.\n"
                "- Destaque semelhanças, diferenças e complementaridades.\n"
                "- Se houver quadros/tabelas, considere todos os itens presentes.\n"
                "- Não peça os documentos novamente.\n"
                "- Seja fiel aos dados."
            )
        else:
            instruction = (
                "Considere o JSON estruturado abaixo, extraído automaticamente de um documento DOCX.\n\n"
                f"Pergunta do usuário:\n{query}\n\n"
                "JSON do documento:\n"
                f"{self.truncate_text(combined_json_text, 25000)}\n\n"
                "Instruções:\n"
                "- Responda com base no JSON.\n"
                "- Diga explicitamente qual arquivo foi considerado.\n"
                "- Não peça o documento novamente.\n"
                "- Se houver quadro/tabela, considere todos os itens presentes.\n"
                "- Seja fiel aos dados."
            )

        self.set_text(self.ai_prompt_txt, instruction)
        self.log("Prompt para IA gerado com base nos JSONs selecionados.")

    # -------------------------------------------------------------------------
    # API
    # -------------------------------------------------------------------------
    def authenticate(self) -> None:
        def worker():
            try:
                self.start_busy("Autenticando...")
                payload = {
                    "client_id": self.client_id_var.get().strip(),
                    "username": self.username_var.get().strip(),
                    "password": self.password_var.get().strip(),
                    "grant_type": self.grant_type_var.get().strip(),
                }
                headers = {"Content-Type": "application/x-www-form-urlencoded"}

                response = requests.post(
                    self.sso_url_var.get().strip(),
                    data=payload,
                    headers=headers,
                    timeout=DEFAULT_AUTH_TIMEOUT,
                )

                if response.status_code != 200:
                    text = response.text
                    self.log(text)
                    self.root.after(0, lambda: self.stop_busy("Erro na autenticação"))
                    self.root.after(0, lambda: messagebox.showerror("Erro", f"Falha na autenticação:\n{text}"))
                    return

                data = response.json()
                self.access_token = data.get("access_token")
                self.log("Autenticação realizada com sucesso.")
                self.stop_busy("Autenticado")

            except Exception as e:
                self.log(f"Erro na autenticação: {e}")
                self.log(traceback.format_exc())
                self.root.after(0, lambda: self.stop_busy("Erro na autenticação"))
                self.root.after(0, lambda: messagebox.showerror("Erro", str(e)))

        self.run_in_thread(worker)

    def send_json_to_ai(self) -> None:
        def worker():
            try:
                if not self.access_token:
                    self.root.after(0, lambda: messagebox.showwarning("Aviso", "Autentique primeiro."))
                    return

                prompt_usuario = self.ai_prompt_txt.get("1.0", "end").strip()
                if not prompt_usuario:
                    self.root.after(0, lambda: messagebox.showwarning("Aviso", "Digite um prompt primeiro."))
                    return

                combined_json_text, selected = self.build_combined_json_context()
                if not combined_json_text:
                    self.root.after(0, lambda: messagebox.showwarning(
                        "Aviso",
                        "Extraia um documento ou selecione JSONs do banco antes de enviar."
                    ))
                    return

                self.start_busy("Preparando JSON para IA...")
                self.busy_step("Montando prompt...")

                final_prompt = (
                    f"{prompt_usuario}\n\n"
                    "==== JSONS SELECIONADOS ====\n"
                    f"{self.truncate_text(combined_json_text, 25000)}"
                )

                payload = {"message": final_prompt}

                headers = {
                    "Authorization": f"Bearer {self.access_token}",
                    "Content-Type": "application/json",
                    "X-Request-Origin": self.origin_var.get().strip(),
                }

                self.busy_step("Enviando para a IA...")
                response = requests.post(
                    self.chat_url_var.get().strip(),
                    json=payload,
                    headers=headers,
                    timeout=DEFAULT_REQUEST_TIMEOUT,
                )

                text = response.text
                try:
                    data = response.json()
                    pretty = json.dumps(data, indent=2, ensure_ascii=False)
                    content = self._extract_message_content(data)
                    output = f"Conteúdo:\n{content}\n\nJSON bruto:\n{pretty}"
                except Exception:
                    output = text

                self.root.after(0, lambda: self.set_text(self.ai_response_txt, output))
                self.log(f"CHAT status: {response.status_code}")
                self.stop_busy("Resposta recebida")

                if response.status_code != 200:
                    self.root.after(0, lambda: messagebox.showerror("Erro", output))

            except Exception as e:
                self.log(f"Erro ao enviar JSON para IA: {e}")
                self.log(traceback.format_exc())
                self.root.after(0, lambda: self.stop_busy("Erro no envio"))
                self.root.after(0, lambda: messagebox.showerror("Erro", str(e)))

        self.run_in_thread(worker)

    def _extract_message_content(self, data: Any) -> str:
        if isinstance(data, list) and data:
            item = data[0]
            if isinstance(item, dict):
                msg = item.get("message")
                if isinstance(msg, dict):
                    content = msg.get("content")
                    if isinstance(content, str):
                        return content

        if isinstance(data, dict):
            msg = data.get("message")
            if isinstance(msg, dict):
                content = msg.get("content")
                if isinstance(content, str):
                    return content

        return json.dumps(data, indent=2, ensure_ascii=False)


