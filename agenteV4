    def reload_json_library(self) -> None:
        try:
            self.start_busy("Carregando documentos do banco...")
            self.busy_step("Lendo registros salvos...")
            self.loaded_json_files.clear()
            self.json_check_vars.clear()

            for child in self.json_list_container.winfo_children():
                child.destroy()

            with self.get_db_connection() as conn:
                with conn.cursor() as cur:
                    cur.execute(
                        f"""
                        SELECT
                            d.id,
                            d.nome_arquivo,
                            d.titulo_documento,
                            d.total_secoes,
                            d.total_tabelas,
                            d.total_quadros,
                            d.criado_em,
                            d.json_conteudo,
                            COALESCE(c.cnt, 0) AS total_chunks
                        FROM {self.db_schema}.{self.db_table} d
                        LEFT JOIN (
                            SELECT documento_id, COUNT(*) AS cnt
                            FROM {self.db_schema}.{self.db_chunks_table}
                            GROUP BY documento_id
                        ) c ON c.documento_id = d.id
                        ORDER BY d.criado_em DESC;
                        """
                    )
                    rows = cur.fetchall()

            for row in rows:
                record = {
                    "id": row[0],
                    "name": row[1],
                    "title": row[2],
                    "total_secoes": row[3],
                    "total_tabelas": row[4],
                    "total_quadros": row[5],
                    "criado_em": row[6],
                    "data": row[7],
                    "total_chunks": row[8],
                }
                self.loaded_json_files.append(record)

            for record in self.loaded_json_files:
                key = str(record["id"])
                var = tk.BooleanVar(value=False)
                self.json_check_vars[key] = var

                text = (
                    f"{record['id']} - {record['name']} "
                    f"(seções={record['total_secoes']}, tabelas={record['total_tabelas']}, "
                    f"quadros={record['total_quadros']}, chunks={record['total_chunks']})"
                )
                chk = ttk.Checkbutton(
                    self.json_list_container,
                    text=text,
                    variable=var,
                    command=self.update_selected_json_info,
                )
                chk.pack(anchor="w", fill="x", padx=4, pady=2)

            self.update_selected_json_info()
            self.log(f"Documentos carregados do banco. Registros: {len(self.loaded_json_files)}")
            self.stop_busy("Documentos carregados")

        except Exception as e:
            self.stop_busy("Erro ao carregar documentos")
            self.log(f"Erro ao carregar documentos do banco: {e}")
            self.log(traceback.format_exc())
            messagebox.showerror("Erro", f"Falha ao carregar documentos do banco:\n{e}")

    def update_selected_json_info(self) -> None:
        count = sum(1 for var in self.json_check_vars.values() if var.get())
        self.json_selected_info_var.set(f"Selecionados: {count}")

    def select_all_jsons(self) -> None:
