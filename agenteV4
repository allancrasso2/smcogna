def normalize_whitespace(text: str) -> str:
    text = text.replace("\xa0", " ")
    text = re.sub(r"[ \t]+", " ", text)
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


def is_probable_title(text: str) -> bool:
    txt = normalize_whitespace(text)
    txt_low = txt.lower()

    if re.match(r"^(quadro|tabela|figura)\s+\d+", txt_low):
        return True
    if re.match(r"^\d+(\.\d+)*\s+", txt):
        return True
    if txt.isupper() and len(txt) <= 120:
        return True
    return False


def guess_section_level(text: str) -> str:
    txt = normalize_whitespace(text)
    if re.match(r"^\d+\.\d+\.\d+", txt):
        return "subsubsecao"
    if re.match(r"^\d+\.\d+", txt):
        return "subsecao"
    if re.match(r"^\d+", txt):
        return "secao"
    return "titulo"


def iter_block_items(document: Document):
    from docx.oxml.text.paragraph import CT_P
    from docx.oxml.table import CT_Tbl

    body = document.element.body
    for child in body.iterchildren():
        if isinstance(child, CT_P):
            yield Paragraph(child, document)
        elif isinstance(child, CT_Tbl):
            yield Table(child, document)


class DocxStructuredExtractor:
    def extract(self, filepath: str) -> Dict[str, Any]:
        doc = Document(filepath)

        metadata = self._extract_metadata(filepath, doc)
        paragraphs: List[ParagraphBlock] = []
        tables: List[TableBlock] = []
        sections: List[SectionBlock] = []
        quadro_map: List[Dict[str, Any]] = []

        current_title = ""
        current_section = ""
        paragraph_order = 0
        table_order = 0
        current_section_idx: Optional[int] = None

        for block in iter_block_items(doc):
            if isinstance(block, Paragraph):
                text = normalize_whitespace(block.text)
                if not text:
                    continue

                style_name = getattr(block.style, "name", "") if getattr(block, "style", None) else ""

                if is_probable_title(text):
                    current_title = text
                    current_section = text

                    sections.append(
                        SectionBlock(
                            title=text,
                            level=guess_section_level(text),
                            paragraphs=[],
                        )
                    )
                    current_section_idx = len(sections) - 1

                elif current_section_idx is None:
                    sections.append(
                        SectionBlock(
                            title="Sem seção explícita",
                            level="livre",
                            paragraphs=[],
                        )
                    )
                    current_section_idx = len(sections) - 1

                paragraph_order += 1
                paragraph_block = ParagraphBlock(
                    order=paragraph_order,
                    text=text,
                    style=style_name,
                    title_context=current_title,
                    section_context=current_section,
                )
                paragraphs.append(paragraph_block)
                sections[current_section_idx].paragraphs.append(text)

            elif isinstance(block, Table):
                raw_rows: List[List[str]] = []
                for row in block.rows:
                    values = [normalize_whitespace(cell.text) for cell in row.cells]
                    values = [v for v in values if v]
                    if values:
                        raw_rows.append(values)

                if not raw_rows:
                    continue

                table_order += 1
                headers = raw_rows[0] if len(raw_rows) > 1 else []
                body_rows = raw_rows[1:] if len(raw_rows) > 1 else raw_rows

                table_rows = [
                    TableRow(row_index=i + 1, values=row_values)
                    for i, row_values in enumerate(body_rows)
                ]

                table_block = TableBlock(
                    order=table_order,
                    title_context=current_title,
                    section_context=current_section,
                    headers=headers,
                    rows=table_rows,
                    raw_rows=raw_rows,
                )
                tables.append(table_block)

                if re.match(r"^(quadro|tabela)\s+\d+", current_title.lower()):
                    quadro_map.append(
                        {
                            "titulo": current_title,
                            "headers": headers,
                            "itens": self._table_to_items(headers, body_rows),
                        }
                    )

        structure = {
            "documento": metadata,
            "resumo_estrutura": {
                "total_paragrafos": len(paragraphs),
                "total_tabelas": len(tables),
                "total_secoes": len(sections),
                "total_quadros_detectados": len(quadro_map),
            },
            "secoes": [asdict(s) for s in sections],
            "paragrafos": [asdict(p) for p in paragraphs],
            "tabelas": [self._table_block_to_dict(t) for t in tables],
            "quadros": quadro_map,
        }

        return structure

    def _extract_metadata(self, filepath: str, doc: Document) -> Dict[str, Any]:
        core = getattr(doc, "core_properties", None)
        path = Path(filepath)
        return {
            "arquivo": path.name,
            "caminho": str(path),
            "extensao": path.suffix.lower(),
            "titulo": getattr(core, "title", "") if core else "",
            "autor": getattr(core, "author", "") if core else "",
            "assunto": getattr(core, "subject", "") if core else "",
            "categoria": getattr(core, "category", "") if core else "",
        }

    def _table_block_to_dict(self, table: TableBlock) -> Dict[str, Any]:
        return {
            "order": table.order,
            "title_context": table.title_context,
            "section_context": table.section_context,
            "headers": table.headers,
            "rows": [asdict(r) for r in table.rows],
            "raw_rows": table.raw_rows,
        }

    def _normalize_key(self, text: str, idx: int) -> str:
        text = normalize_whitespace(text).lower()
        text = re.sub(r"[^\w\s]", "", text)
        text = re.sub(r"\s+", "_", text).strip("_")
        return text or f"coluna_{idx}"

    def _table_to_items(self, headers: List[str], rows: List[List[str]]) -> List[Dict[str, Any]]:
        items: List[Dict[str, Any]] = []

        if headers:
            norm_headers = [self._normalize_key(h, i + 1) for i, h in enumerate(headers)]
            for row in rows:
                item: Dict[str, Any] = {}
                for i, value in enumerate(row):
                    key = norm_headers[i] if i < len(norm_headers) else f"coluna_{i+1}"
                    item[key] = value
                items.append(item)
        else:
            for row in rows:
                items.append({"valores": row})

        return items


class JsonChunker:
    def __init__(self, max_chars: int = DEFAULT_CHUNK_MAX_CHARS, overlap: int = DEFAULT_CHUNK_OVERLAP) -> None:
        self.max_chars = max(300, max_chars)
        self.overlap = max(0, min(overlap, self.max_chars - 50))

    def build_chunks(self, structure: Dict[str, Any]) -> List[ChunkBlock]:
        chunks: List[ChunkBlock] = []
        order = 1

        # Seções
        for idx, sec in enumerate(structure.get("secoes", []), start=1):
            title = normalize_whitespace(sec.get("title", "") or f"Seção {idx}")
            paras = sec.get("paragraphs", [])
            text = "\n\n".join([normalize_whitespace(p) for p in paras if normalize_whitespace(p)]).strip()
            for piece_idx, piece in enumerate(self._split_text(text), start=1):
                chunks.append(
                    ChunkBlock(
                        tipo_bloco="secao",
                        titulo_bloco=title,
                        ordem_bloco=order,
                        conteudo=piece,
                        metadata={
                            "section_index": idx,
                            "piece_index": piece_idx,
                            "level": sec.get("level", ""),
                        },
                    )
                )
                order += 1

        # Quadros
        for idx, quadro in enumerate(structure.get("quadros", []), start=1):
            titulo = normalize_whitespace(quadro.get("titulo", "") or f"Quadro {idx}")
            headers = quadro.get("headers", [])
            itens = quadro.get("itens", [])

            if headers:
                hdr = " | ".join(headers)
                text_parts = [f"{titulo}\nHeaders: {hdr}"]
            else:
                text_parts = [titulo]

            for item_idx, item in enumerate(itens, start=1):
                text_parts.append(f"Item {item_idx}: {json.dumps(item, ensure_ascii=False)}")

            quadro_text = "\n".join(text_parts)
            for piece_idx, piece in enumerate(self._split_text(quadro_text), start=1):
                chunks.append(
                    ChunkBlock(
                        tipo_bloco="quadro",
                        titulo_bloco=titulo,
                        ordem_bloco=order,
                        conteudo=piece,
                        metadata={
                            "quadro_index": idx,
                            "piece_index": piece_idx,
                            "headers": headers,
                        },
                    )
                )
                order += 1

        # Tabelas não mapeadas em quadros
        for idx, tabela in enumerate(structure.get("tabelas", []), start=1):
            title = normalize_whitespace(tabela.get("title_context", "") or f"Tabela {idx}")
            headers = tabela.get("headers", [])
            rows = tabela.get("raw_rows", [])

            parts = [title]
            if headers:
                parts.append("Headers: " + " | ".join(headers))
            for row_idx, row in enumerate(rows, start=1):
                parts.append(f"Linha {row_idx}: {' | '.join(row)}")

            tabela_text = "\n".join(parts)
            for piece_idx, piece in enumerate(self._split_text(tabela_text), start=1):
                chunks.append(
                    ChunkBlock(
                        tipo_bloco="tabela",
                        titulo_bloco=title,
                        ordem_bloco=order,
                        conteudo=piece,
                        metadata={
                            "tabela_index": idx,
                            "piece_index": piece_idx,
                            "headers": headers,
                        },
                    )
                )
                order += 1

        return chunks

    def _split_text(self, text: str) -> List[str]:
        text = normalize_whitespace(text)
        if not text:
            return []

        parts: List[str] = []
        start = 0
        text_len = len(text)

        while start < text_len:
            end = min(start + self.max_chars, text_len)
            current = text[start:end]

            if end < text_len:
                last_break = max(
                    current.rfind("\n\n"),
                    current.rfind(". "),
                    current.rfind("; "),
                    current.rfind(": "),
                )
                if last_break > 200:
                    end = start + last_break + 1
                    current = text[start:end]

            current = normalize_whitespace(current)
            if current:
                parts.append(current)

            if end >= text_len:
                break
            start = max(0, end - self.overlap)

        return parts


