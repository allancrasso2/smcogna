    def add_current_json_to_library(self) -> None:
        if not self.current_json:
            messagebox.showwarning("Aviso", "Nenhum JSON atual foi gerado.")
            return

        try:
            self.start_busy("Salvando JSON no banco...")
            self.busy_step("Inserindo documento estruturado...")

            documento = self.current_json.get("documento", {})
            resumo = self.current_json.get("resumo_estrutura", {})

            nome_arquivo = documento.get("arquivo", "documento_sem_nome.json")
            titulo_documento = documento.get("titulo", "") or nome_arquivo
            usuario_nome = self.username_var.get().strip() or "postgres"

            chunk_blocks = self.chunker.build_chunks(self.current_json)

            with self.get_db_connection() as conn:
                with conn.cursor() as cur:
                    cur.execute(
                        f"""
                        INSERT INTO {self.db_schema}.{self.db_table} (
                            nome_arquivo,
                            titulo_documento,
                            json_conteudo,
                            total_secoes,
                            total_tabelas,
                            total_quadros,
                            usuario_nome
                        )
                        VALUES (%s, %s, %s, %s, %s, %s, %s)
                        RETURNING id;
                        """,
                        (
                            nome_arquivo,
                            titulo_documento,
                            Json(self.current_json),
                            resumo.get("total_secoes", 0),
                            resumo.get("total_tabelas", 0),
                            resumo.get("total_quadros_detectados", 0),
                            usuario_nome,
                        )
                    )
                    new_id = cur.fetchone()[0]

                    self.busy_step("Salvando chunks no banco...")
                    for chunk in chunk_blocks:
                        cur.execute(
                            f"""
                            INSERT INTO {self.db_schema}.{self.db_chunks_table} (
                                documento_id,
                                tipo_bloco,
                                titulo_bloco,
                                ordem_bloco,
                                conteudo,
                                metadata
                            )
                            VALUES (%s, %s, %s, %s, %s, %s)
                            """,
                            (
                                new_id,
                                chunk.tipo_bloco,
                                chunk.titulo_bloco,
                                chunk.ordem_bloco,
                                chunk.conteudo,
                                Json(chunk.metadata),
                            )
                        )
                conn.commit()

            self.current_doc_id = new_id
            self.stop_busy(f"JSON salvo no banco (ID {new_id})")
            self.log(f"JSON atual salvo no banco com ID {new_id}.")
            self.log(f"Chunks salvos: {len(chunk_blocks)}")
            self.chunk_status_var.set(f"Chunks: {len(chunk_blocks)}")
            self.reload_json_library()
            messagebox.showinfo("Sucesso", f"JSON e chunks salvos no banco com ID {new_id}.")

        except Exception as e:
            self.log(f"Erro ao salvar JSON no banco: {e}")
            self.log(traceback.format_exc())
            self.stop_busy("Erro ao salvar no banco")
            messagebox.showerror("Erro", f"Falha ao salvar JSON no banco:\n{e}")

    # -------------------------------------------------------------------------
    # Prompt / Retrieval
    # -------------------------------------------------------------------------
    def get_relevant_chunks_from_db(
        self,
        query: str,
        selected_records: List[Dict[str, Any]],
        top_k: int,
    ) -> List[Dict[str, Any]]:
        if not selected_records:
            return []

        selected_ids = [int(r["id"]) for r in selected_records]
        tokens = [t.strip() for t in re.split(r"\W+", query.lower()) if t.strip()]
        if not tokens:
            tokens = ["documento"]

        like_clauses = []
        params: List[Any] = []

        for token in tokens:
            like_clauses.append("(LOWER(c.conteudo) LIKE %s OR LOWER(c.titulo_bloco) LIKE %s)")
            params.extend([f"%{token}%", f"%{token}%"])

        sql_where = " OR ".join(like_clauses)

        query_sql = f"""
            SELECT
                c.id,
                c.documento_id,
                d.nome_arquivo,
                d.titulo_documento,
                c.tipo_bloco,
                c.titulo_bloco,
                c.ordem_bloco,
                c.conteudo,
                c.metadata,
                (
                    {" + ".join(["CASE WHEN (LOWER(c.conteudo) LIKE %s OR LOWER(c.titulo_bloco) LIKE %s) THEN 1 ELSE 0 END" for _ in tokens])}
                ) AS score
            FROM {self.db_schema}.{self.db_chunks_table} c
            JOIN {self.db_schema}.{self.db_table} d
              ON d.id = c.documento_id
            WHERE c.documento_id = ANY(%s)
              AND ({sql_where})
            ORDER BY score DESC, c.documento_id ASC, c.ordem_bloco ASC
            LIMIT %s
        """

        score_params: List[Any] = []
        for token in tokens:
            score_params.extend([f"%{token}%", f"%{token}%"])

        final_params = score_params + [selected_ids] + params + [top_k]

        with self.get_db_connection() as conn:
            with conn.cursor() as cur:
                cur.execute(query_sql, final_params)
                rows = cur.fetchall()

        results = []
        for row in rows:
            results.append(
                {
                    "chunk_id": row[0],
                    "documento_id": row[1],
                    "nome_arquivo": row[2],
                    "titulo_documento": row[3],
                    "tipo_bloco": row[4],
                    "titulo_bloco": row[5],
                    "ordem_bloco": row[6],
                    "conteudo": row[7],
                    "metadata": row[8],
                    "score": row[9],
                }
            )
        return results

    def build_combined_json_context(self) -> Tuple[str, List[Dict[str, Any]]]:
        selected = self.get_selected_json_records()

        if not selected:
            if self.current_json:
                payload = {
                    "modo": "json_atual",
                    "documentos": [
                        {
                            "arquivo": self.current_json.get("documento", {}).get("arquivo", "json_atual"),
                            "conteudo": self.current_json
                        }
                    ]
                }
                return json.dumps(payload, indent=2, ensure_ascii=False), []
            return "", []

        payload = {
            "modo": "comparativo" if len(selected) > 1 else "individual",
            "total_documentos": len(selected),
            "documentos": [],
        }

        for record in selected:
            payload["documentos"].append(
                {
                    "id": record["id"],
                    "arquivo": record["name"],
                    "titulo": record["title"],
                    "conteudo": record["data"],
                }
            )

        return json.dumps(payload, indent=2, ensure_ascii=False), selected

    def preview_selected_chunks(self) -> None:
        def worker():
            try:
                selected = self.get_selected_json_records()
                if not selected:
                    self.root.after(0, lambda: messagebox.showwarning("Aviso", "Selecione pelo menos um documento do banco."))
                    return

                query = self.json_query_var.get().strip()
                if not query:
                    self.root.after(0, lambda: messagebox.showwarning("Aviso", "Digite uma consulta primeiro."))
                    return

                top_k = self.safe_int(self.top_k_var.get(), DEFAULT_TOP_K)

                self.start_busy("Buscando chunks relevantes...")
                self.busy_step("Consultando banco...")

                results = self.get_relevant_chunks_from_db(query, selected, top_k)

                if not results:
                    self.root.after(0, lambda: self.set_text(self.retrieved_chunks_txt, "Nenhum chunk relevante encontrado."))
                    self.stop_busy("Nenhum chunk encontrado")
                    return

                lines: List[str] = []
                for idx, item in enumerate(results, start=1):
                    lines.append(
                        f"[Chunk {idx} | doc={item['documento_id']} | arquivo={item['nome_arquivo']} | "
                        f"tipo={item['tipo_bloco']} | bloco={item['titulo_bloco']} | score={item['score']}]\n"
                        f"{item['conteudo']}"
                    )

                output = "\n\n".join(lines)
                self.root.after(0, lambda: self.set_text(self.retrieved_chunks_txt, output))
                self.stop_busy(f"{len(results)} chunks encontrados")

            except Exception as e:
                self.log(f"Erro ao buscar chunks: {e}")
                self.log(traceback.format_exc())
                self.stop_busy("Erro na busca")
                self.root.after(0, lambda: messagebox.showerror("Erro", str(e)))

        self.run_in_thread(worker)

    def generate_prompt_for_ai(self) -> None:
